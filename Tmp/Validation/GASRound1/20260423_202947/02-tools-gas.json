[
    {
        "name":  "query-gas-asset-summary",
        "description":  "Query a GAS asset summary for GameplayAbility, GameplayEffect, AttributeSet, or Actor Blueprint bindings.",
        "inputSchema":  {
                            "type":  "object",
                            "properties":  {
                                               "asset_path":  {
                                                                  "type":  "string",
                                                                  "description":  "GAS asset or Actor Blueprint asset path"
                                                              }
                                           },
                            "required":  [
                                             "asset_path"
                                         ]
                        },
        "metadata":  {
                         "kind":  "query",
                         "resource_scope":  "asset",
                         "mutates":  false,
                         "supports_batch":  false,
                         "supports_dry_run":  false,
                         "supports_compile":  false,
                         "supports_save":  false
                     }
    },
    {
        "name":  "create-gameplay-ability",
        "description":  "Create a GameplayAbility Blueprint and configure common GAS v1 defaults such as tags, policies, cost, and cooldown classes.",
        "inputSchema":  {
                            "type":  "object",
                            "properties":  {
                                               "asset_path":  {
                                                                  "type":  "string",
                                                                  "description":  "GameplayAbility Blueprint asset path"
                                                              },
                                               "parent_class":  {
                                                                    "type":  "string",
                                                                    "description":  "Optional parent class path; defaults to /Script/GameplayAbilities.GameplayAbility"
                                                                },
                                               "ability_tags":  {
                                                                    "type":  "array",
                                                                    "description":  "Existing GameplayTags to assign as ability asset tags",
                                                                    "items":  {
                                                                                  "type":  "string"
                                                                              }
                                                                },
                                               "activation_owned_tags":  {
                                                                             "type":  "array",
                                                                             "description":  "Existing GameplayTags granted while active",
                                                                             "items":  {
                                                                                           "type":  "string"
                                                                                       }
                                                                         },
                                               "activation_required_tags":  {
                                                                                "type":  "array",
                                                                                "description":  "Existing GameplayTags required to activate",
                                                                                "items":  {
                                                                                              "type":  "string"
                                                                                          }
                                                                            },
                                               "activation_blocked_tags":  {
                                                                               "type":  "array",
                                                                               "description":  "Existing GameplayTags blocking activation",
                                                                               "items":  {
                                                                                             "type":  "string"
                                                                                         }
                                                                           },
                                               "instancing_policy":  {
                                                                         "type":  "string",
                                                                         "description":  "Ability instancing policy",
                                                                         "enum":  [
                                                                                      "non_instanced",
                                                                                      "instanced_per_actor",
                                                                                      "instanced_per_execution"
                                                                                  ]
                                                                     },
                                               "net_execution_policy":  {
                                                                            "type":  "string",
                                                                            "description":  "Ability net execution policy",
                                                                            "enum":  [
                                                                                         "local_predicted",
                                                                                         "local_only",
                                                                                         "server_initiated",
                                                                                         "server_only"
                                                                                     ]
                                                                        },
                                               "replication_policy":  {
                                                                          "type":  "string",
                                                                          "description":  "Ability replication policy",
                                                                          "enum":  [
                                                                                       "replicate_no",
                                                                                       "replicate_yes"
                                                                                   ]
                                                                      },
                                               "cost_gameplay_effect":  {
                                                                            "type":  "string",
                                                                            "description":  "GameplayEffect class or Blueprint asset path used as cost"
                                                                        },
                                               "cooldown_gameplay_effect":  {
                                                                                "type":  "string",
                                                                                "description":  "GameplayEffect class or Blueprint asset path used as cooldown"
                                                                            },
                                               "compile":  {
                                                               "type":  "boolean",
                                                               "description":  "Compile created Blueprint"
                                                           },
                                               "save":  {
                                                            "type":  "boolean",
                                                            "description":  "Save created Blueprint"
                                                        },
                                               "dry_run":  {
                                                               "type":  "boolean",
                                                               "description":  "Validate only"
                                                           }
                                           },
                            "required":  [
                                             "asset_path"
                                         ]
                        },
        "metadata":  {
                         "kind":  "write",
                         "resource_scope":  "asset",
                         "mutates":  true,
                         "supports_batch":  false,
                         "supports_dry_run":  true,
                         "supports_compile":  false,
                         "supports_save":  true
                     }
    },
    {
        "name":  "create-gameplay-effect",
        "description":  "Create a GameplayEffect Blueprint and configure v1 duration, period, granted tags, and simple constant modifiers.",
        "inputSchema":  {
                            "type":  "object",
                            "properties":  {
                                               "asset_path":  {
